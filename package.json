{
  "name": "infomap-online",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "homepage": "/infomap",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "serve:export": "node scripts/serve-export.mjs",
    "check": "npm run lint && npm run format:check && npm run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:smoke",
    "test:smoke": "playwright test",
    "test:smoke:ui": "playwright test --ui",
    "verify": "npm run check && npm run build && npm run test:smoke"
  },
  "dependencies": {
    "@chakra-ui/react": "3.35.0",
    "@emotion/react": "11.14.0",
    "@fontsource/open-sans": "^4.5.13",
    "@fontsource/philosopher": "^4.5.11",
    "@mapequation/infomap": "^2.10.1",
    "@matejmazur/react-katex": "^3.1.3",
    "arg": "^5.0.2",
    "chakra-react-select": "6.1.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "next": "15.5.15",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-dropzone": "^14.2.3",
    "react-icons": "^4.6.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@playwright/test": "^1.55.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "typescript": "5.9.3"
  }
}
